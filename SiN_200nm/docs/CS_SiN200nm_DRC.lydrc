<?xml version="1.0" encoding="utf-8"?>
<klayout-macro>
 <description/>
 <version/>
 <category>drc</category>
 <prolog/>
 <epilog/>
 <doc/>
 <autorun>false</autorun>
 <autorun-early>false</autorun-early>
 <priority>0</priority>
 <shortcut/>
 <show-in-menu>true</show-in-menu>
 <group-name>drc_scripts</group-name>
 <menu-path>tools_menu.drc.end</menu-path>
 <interpreter>dsl</interpreter>
 <dsl-interpreter-name>drc-dsl-xml</dsl-interpreter-name>
 <text>#CORNERSTONE Proprietary
#Released: 29/05/2026
#Version: 4.0
#Author: Shengqi Yin, Emre Kaplan, Bilge Yagci
#Report any issue to cornerstone@soton.ac.uk
#Technology Platform: Silicon Nitride 200nm
#Note: This script performs a pre-DRC run. A full DRC run will be performed by CORNERSTONE Team

if $input
  source($input)
end
if $report
  report("DRC SiN-vis", $report)
else
  report("DRC SiN-vis")
end



#GDS layers

#SiN Etch 1 - Light field (GDS 203)
sin_light_layer = input(203,0)

#SiN Etch 1 - Dark field (GDS 204)
sin_dark_layer = input(204, 0)


#Heater Filaments (GDS 39)
fil= input(39, 0)

#Heater Contact Pads (GDS 41)
pad = input(41, 0)

#Label (GDS 100)
label =input(100,0)

#Cell Outline (Design area) (GDS 99)
cell = input(99, 0)

#Cladding Opening window - Dark field (GDS 22)
sin_clado_layer = input(22,0)



design_grid = 0.001
layers.each { |layer|  input(layer).ongrid(design_grid).output("#{layer.to_s} grid violations")}

#Check correct design area is used
design_area = 15450.0.um*11470.0.um
cell.without_area(design_area).output("Correct design area violation")



def check_minimum_feature(layer,max_width,max_length=20.001)
  max_feature_perimeter = 2*(max_width+max_length)
  max_feature_area = max_width*max_length
  layer_feature_area = layer.width(max_width,euclidian).polygons.with_area(max_feature_area,nil)
  layer_feature_perimeter = layer.width(max_width,euclidian).polygons.with_perimeter(max_feature_perimeter,nil)
  layer_min_feature = layer_feature_area.or(layer_feature_perimeter)
return layer_min_feature
end
def check_minimum_gap_feature(layer,max_gap,max_length = 20.001)
  max_gap_perimeter = 2*(max_gap+max_length)
  max_gap_area = max_gap*max_length
  layer_feature_area = layer.space(max_gap,euclidian).polygons.with_area(max_gap_area,nil)
  layer_feature_perimeter = layer.space(max_gap,euclidian).polygons.with_perimeter(max_gap_perimeter,nil)
  layer_min_feature = layer_feature_area.or(layer_feature_perimeter)
return layer_min_feature
end

# Use a tile size of 20mm
tiles(20.mm)
# Use 4 threads
threads(4)
angle_lim= 1

max_feature_length=20.001.um
feature_margin = -0.001.um

info ("DRC section")
# Minimum feature size for light field
sin_light_layer.width(0.2+feature_margin, angle_limit(angle_lim)).without_area(0).output("Minimum feature size violation (GDS203&lt;200nm)") # absolute minimum width
sin_light_layer_feature = check_minimum_feature(sin_light_layer,0.35+feature_margin,max_feature_length)
sin_light_layer_feature.without_area(0).output("Minimum feature size violation (GDS203&lt;350nm for features &gt;=20um)") # conditional width rule

# Minimum gap for light field
sin_light_layer.space(0.2+feature_margin, angle_limit(angle_lim)).without_area(0).output("Minimum gap violation (GDS203&lt;200nm)")
sin_light_layer_gap = check_minimum_gap_feature(sin_light_layer,0.25+feature_margin,max_feature_length)
sin_light_layer_gap.without_area(0).output("Minimum gap violation (GDS203&lt;250nm for gaps &gt;=20um)") # conditional gap rule


# Minimum feature size for dark field
sin_dark_layer.width(0.20+feature_margin, angle_limit(angle_lim)).without_area(0).output("Minimum feature size violation (GDS204&lt;200nm)")
sin_dark_layer_feature = check_minimum_feature(sin_dark_layer,0.25+feature_margin,max_feature_length)
sin_dark_layer_feature.without_area(0).output("Minimum feature size violation (GDS204&lt;250nm for features &gt;=20um)") # conditional width rule


# Minimum gap for dark field
sin_dark_layer.space(0.20+feature_margin, angle_limit(angle_lim)).without_area(0).output("Minimum gap violation (GDS204&lt;200nm)")
sin_dark_layer_gap = check_minimum_gap_feature(sin_dark_layer,0.35+feature_margin,max_feature_length)
sin_dark_layer_gap.without_area(0).output("Minimum gap violation (GDS204&lt;350nm for gaps &gt;=20um)") # conditional gap rule




# Minimum feature size for Heater Filaments
fil.width(0.6, angle_limit(angle_lim)).output("Minimum width violation (GDS39 &lt; 600nm)")


# Minimum gap for Heater Filaments
fil.space(5.0, angle_limit(angle_lim)).output("Minimum gap violation (GDS39 &lt; 5um)")


# Minimum feature size for Contact Pad
pad.width(2.0, angle_limit(angle_lim)).output("Minimum width violation (GDS41 &lt; 2um)")


# Minimum gap for Contact Pad
pad.space(5.0, angle_limit(angle_lim)).output("Minimum gap violation (GDS41 &lt; 5um)")

# Minimum feature size for Label
label.width(0.25, angle_limit(angle_lim)).output("Minimum width violation (GDS100 &lt; 250nm)")

# Minimum gap for Label
label.space(0.25, angle_limit(angle_lim)).output("Minimum gap violation (GDS100 &lt; 250nm)")


# Minimum feature size for cladding opening
sin_clado_layer.width(20.0, angle_limit(angle_lim)).output("Minimum width violation (GDS22 &lt; 20um)")

# Minimum gap for cladding opening
sin_clado_layer.space(20.0, angle_limit(angle_lim)).output("Minimum gap violation (GDS22 &lt; 20um)")

# Warning checks in cladding-overlapped SiN regions
sin_light_overlapped_by_clad = sin_light_layer.and(sin_clado_layer)
sin_light_overlapped_by_clad.space(0.4+feature_margin, angle_limit(angle_lim)).without_area(0).output("WARNING: Pinhole-induced undercut notice in GDS203 (GDS203 in overlap with GDS22 &lt; 400nm)")

sin_dark_overlapped_by_clad = sin_dark_layer.and(sin_clado_layer)
sin_dark_overlapped_by_clad.width(0.4+feature_margin, angle_limit(angle_lim)).without_area(0).output("WARNING: Pinhole-induced undercut notice in GDS204 (GDS204 in overlap with GDS22 &lt; 400nm)")

















</text>
</klayout-macro>
